PORT=3000
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DATABASE?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1h
BCRYPT_ROUNDS=12

# Shared Redis for Socket.IO multi-node broadcasts and express-rate-limit (omit for single-process dev)
REDIS_URL=redis://localhost:6379
# With several replicas, either enable sticky sessions on the load balancer for Socket.IO polling or prefer the websocket transport from clients
